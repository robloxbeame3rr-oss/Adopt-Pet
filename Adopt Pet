<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AdoptMeCalculator - Roadmap</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body {
  margin: 0;
  font-family: Inter, sans-serif;
  background: radial-gradient(circle at top, #0b0f19, #000);
  color: white;
}

/* NAV */
nav {
  display: flex;
  justify-content: space-between;
  padding: 18px 40px;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

nav h2 { font-size: 18px; }

nav a {
  margin: 0 10px;
  color: #aaa;
  text-decoration: none;
  font-size: 14px;
}

nav a:hover { color: white; }

/* HERO */
.hero {
  padding: 60px 40px 20px;
}

.hero h1 {
  font-size: 48px;
  margin: 0;
}

.hero p {
  color: #9ca3af;
  max-width: 600px;
}

/* GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  padding: 40px;
}

.card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16px;
  padding: 20px;
  backdrop-filter: blur(12px);
}

.title {
  font-size: 12px;
  letter-spacing: 2px;
  color: #6ee7b7;
}

.value {
  font-size: 28px;
  margin: 10px 0;
}

.sub {
  color: #9ca3af;
  font-size: 13px;
}

/* BUTTONS */
.centerButtons {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin: 10px 0 40px;
}

.ovalBtn {
  padding: 12px 26px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.15);
  background: rgba(255,255,255,0.05);
  color: white;
  cursor: pointer;
  transition: 0.2s;
  font-size: 13px;
}

.ovalBtn:hover {
  background: rgba(99,102,241,0.25);
  border-color: #6366f1;
  transform: translateY(-2px);
}

/* 🧮 UPGRADED CALCULATOR */
.calcBox {
  margin: 0 40px 60px;
  padding: 20px;
  border-radius: 16px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  backdrop-filter: blur(12px);
}

.calcGrid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 10px;
}

input {
  padding: 12px;
  border-radius: 10px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(0,0,0,0.4);
  color: white;
}

.calcBtn {
  margin-top: 12px;
  width: 100%;
  padding: 10px;
  border-radius: 10px;
  background: #6366f1;
  border: none;
  color: white;
  cursor: pointer;
}

.result {
  margin-top: 12px;
  color: #9ca3af;
  line-height: 1.6;
}
</style>
</head>

<body>

<nav>
  <h2>AdoptMeCalculator</h2>

  <div>
    <a href="#">Home</a>
    <a href="#">Dashboard</a>
    <a href="#">Roadmap</a>
  </div>
</nav>

<div class="hero">
  <h1>Roadmap</h1>
  <p>Track value, optimize trades, and analyze market demand.</p>
</div>

<!-- TOP CARDS -->
<div class="grid">

  <div class="card">
    <div class="title">VAULT</div>
    <div class="value">0</div>
    <div class="sub">stable high-tier pets</div>
  </div>

  <div class="card">
    <div class="title">ENGINE</div>
    <div class="value">0</div>
    <div class="sub">active trading assets</div>
  </div>

  <div class="card">
    <div class="title">DEAD WEIGHT</div>
    <div class="value">0</div>
    <div class="sub">low value inventory</div>
  </div>

</div>

<!-- BUTTONS -->
<div class="centerButtons">

  <button class="ovalBtn" onclick="location.href='trade-posts.html'">
    Trade Posts
  </button>

  <button class="ovalBtn" onclick="location.href='pet-demand.html'">
    Pet Demand
  </button>

</div>

<!-- 🧮 ADVANCED TRADE CALCULATOR -->
<div class="calcBox">
  <h3>Trade Calculator</h3>
  <p class="sub">Multi-source value system with demand weighting</p>

  <div class="calcGrid">
    <input id="yourPet" placeholder="Your Pet (e.g. Frost Dragon)">
    <input id="theirPet" placeholder="Their Pet (e.g. Owl)">
  </div>

  <button class="calcBtn" onclick="calculate()">Calculate Trade</button>

  <div class="result" id="result"></div>
</div>

<script>

// 🧠 VALUE + DEMAND SYSTEM
const pets = {
  "shadow dragon": { v: 100, d: 3 },
  "bat dragon": { v: 85, d: 3 },
  "giraffe": { v: 80, d: 3 },
  "frost dragon": { v: 55, d: 3 },
  "owl": { v: 45, d: 3 },
  "parrot": { v: 40, d: 2 },
  "evil unicorn": { v: 38, d: 2 },
  "crow": { v: 35, d: 2 },
  "turtle": { v: 30, d: 2 },
  "kangaroo": { v: 28, d: 2 },
  "dodo": { v: 15, d: 1 },
  "unicorn": { v: 12, d: 1 },
  "dragon": { v: 10, d: 1 }
};

function normalize(x){
  return x.toLowerCase().trim();
}

function stars(n){
  return "⭐".repeat(n) + "☆".repeat(3-n);
}

function value(p){
  if(!pets[p]) return null;
  let base = pets[p].v;
  let demand = pets[p].d;

  let multiplier = demand === 3 ? 1.25 : demand === 2 ? 1.1 : 1;

  return {
    base,
    demand,
    total: Math.round(base * multiplier)
  };
}

function calculate(){
  let a = normalize(document.getElementById("yourPet").value);
  let b = normalize(document.getElementById("theirPet").value);

  let va = value(a);
  let vb = value(b);

  if(!va || !vb){
    document.getElementById("result").innerText =
      "❓ One or both pets not found in database";
    return;
  }

  let diff = vb.total - va.total;

  let outcome =
    diff > 5 ? "WIN 🎉" :
    diff >= -5 ? "FAIR 🤝" :
    "LOSE ❌";

  document.getElementById("result").innerHTML = `
    Your Pet: <b>${a}</b> (${va.total}) ${stars(va.demand)} <br>
    Their Pet: <b>${b}</b> (${vb.total}) ${stars(vb.demand)} <br><br>
    Difference: <b>${diff}</b> → <b>${outcome}</b>
  `;
}

</script>

</body>
</html>
